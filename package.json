{
  "name": "bizora-app-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:desktop": "tsc -b && vite build --mode desktop",
    "preview": "vite preview",
    "desktop:dev": "electron .",
    "desktop": "npm run build:desktop && electron .",
    "desktop:pack": "npm run build:desktop && electron-builder --win"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.487.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "^7.5.0",
    "react-toastify": "^11.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0"
  },
  "build": {
    "appId": "app.bizora.desktop",
    "productName": "Bizora App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../bizora/target/bizora-1.0.0.jar",
        "to": "bizora/target/bizora-1.0.0.jar"
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "public/icon.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
